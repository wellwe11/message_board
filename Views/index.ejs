<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>

    <%- include("./components/nav") %>

    <% if (messages && messages.length > 0) { %>
    <ul>
        <% messages.forEach((message) => { %>
            <%- include("./components/message", { message }) %>
        <% }); %>
    </ul>

    <% } %>
  </body>
</html>
